<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ColorGuesser"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ColorGuesser.MainPage">
    
    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:ColorToHexRgbStringConverter x:Key="ColorToHexRgbStringConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>
    
    <Grid RowDefinitions="1*, 1*">
        <Grid ColumnDefinitions="1*, 1*" ColumnSpacing="5">
            <!-- User Color Input Controller -->
            <VerticalStackLayout Padding="6">
                <local:RgbColorControllerView x:Name="UserColorInput" Margin="25, 0"/>
                <Label BindingContext="{x:Reference UserColorInput}" Text="{Binding Color, Converter={StaticResource ColorToHexRgbStringConverter}}" FontAttributes="Bold" FontSize="24" HorizontalOptions="Center"/>
            </VerticalStackLayout>
            
            <!-- Random Color Picked Display -->
            <Grid RowDefinitions="1*, Auto" Grid.Column="1" Padding="6">
                <BoxView x:Name="PickedColorDisplay" BackgroundColor="{Binding ColorPicked}" HorizontalOptions="Fill" VerticalOptions="Fill"/>
                
                <Grid ColumnDefinitions="Auto, Auto" Grid.Row="1">
                    <Label x:Name="PickedColorDisplayLabel" BindingContext="{x:Reference PickedColorDisplay}" FontAttributes="Bold" FontSize="24" HorizontalOptions="Start"/>
                    <Button Text="New Random Color" Clicked="PickNewRandomColor_ButtonOnClick" MinimumHeightRequest="0" MinimumWidthRequest="0" Padding="0" VerticalOptions="Center" HorizontalOptions="End" Grid.Column="1"/>
                </Grid>
            </Grid>
        </Grid>
        
        <!-- User Color Input Button Sender -->
        <Grid Grid.Row="1" HorizontalOptions="Center" VerticalOptions="Center">
            <Button BindingContext="{x:Reference SendButtonGrid}" Clicked="GuessColorButton_OnClicked" WidthRequest="{Binding Width}"/>
            
            <Grid x:Name="SendButtonGrid" ColumnDefinitions="Auto, Auto" ColumnSpacing="4" HorizontalOptions="Center" VerticalOptions="Center" InputTransparent="True">
                <Label Text="I'm sure the color is" InputTransparent="True"/>
                <BoxView BindingContext="{x:Reference UserColorInput}" BackgroundColor="{Binding Color}" HeightRequest="14" WidthRequest="45" Grid.Column="1" InputTransparent="True"/>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
