<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ColorGuesser"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="ColorGuesser.MainPage">
    
    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:ColorToHexRgbStringConverter x:Key="ColorToHexRgbStringConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>
    
    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Grid RowDefinitions="Auto, Auto, Auto">
                <BoxView Color="{Binding PickedHexColor}" HeightRequest="30" HorizontalOptions="Fill"/>
                
                <Label x:Name="PickedColor" Text="{Binding PickedHexColor}" FontSize="24" FontAttributes="Bold" VerticalTextAlignment="Center" HorizontalTextAlignment="Center" HeightRequest="32" BackgroundColor="{Binding PickedHexColorCodeOnly, StringFormat='#8D{0}'}" Grid.Row="1"/>
                    
                <BoxView Color="{Binding PickedHexColor}" HeightRequest="12" HorizontalOptions="Fill" Grid.Row="2"/>
            </Grid> 
            
            <BoxView Height="45" HorizontalOptions="Fill"/>
            
            <Label x:Name="UserColorToHex_Label" BindingContext="{x:Reference UserColorInput}" Text="{Binding Color, Converter={StaticResource ColorToHexRgbStringConverter}}" />
            <local:RgbColorControllerView x:Name="UserColorInput"/>

            <Grid>
                <Button Clicked="GuessColorButton_OnClicked" BackgroundColor="#3e3e5e"/>    
                
                <Grid ColumnDefinitions="Auto, Auto" VerticalOptions="Center" HorizontalOptions="Center" ColumnSpacing="4" InputTransparent="True">
                    <Label Text="I'm sure the color is "/>
                    <BoxView BindingContext="{x:Reference UserColorInput}" HeightRequest="14" WidthRequest="56" Color="{Binding Color}" Grid.Column="1"/>
                </Grid>
            </Grid>
            
            <Label Text="{Binding IsColorWritedCorrect}" FontSize="28" HorizontalOptions="Center"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
